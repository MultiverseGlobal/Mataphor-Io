{
    "manifest_version": 3,
    "name": "Metaphor IO",
    "version": "1.0.0",
    "description": "The invisible layer between capture and destination. Drop it in, it puts it where it belongs.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background/background.js"
    },
    "permissions": [
        "activeTab",
        "storage",
        "clipboardRead",
        "scripting"
    ],
    "host_permissions": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://chat.openai.com/*",
                "https://chatgpt.com/*"
            ],
            "js": ["content/chatgpt.js"]
        },
        {
            "matches": ["https://claude.ai/*"],
            "js": ["content/claude.js"]
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}